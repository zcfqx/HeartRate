<Window x:Class="HeartRateMonitor.App.Views.DevicePickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="选择设备" Width="360" Height="480"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A2E"
        Foreground="#E0E0E0"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="选择设备" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
        </Grid>

        <Border Grid.Row="1" Background="#0DFFFFFF" CornerRadius="8" Padding="4">
            <ListBox ItemsSource="{Binding Devices}"
                     Background="Transparent" Foreground="#E0E0E0"
                     BorderThickness="0"
                     ItemTemplate="{StaticResource DeviceItemTemplate}"
                     SelectedItem="{Binding SelectedDevice}"/>
        </Border>

        <Button Grid.Row="2" Content="{Binding ScanButtonText}"
                Command="{Binding ToggleScanCommand}"
                Background="#6366F1" Foreground="White" BorderThickness="0"
                Padding="16,8" Margin="0,16,0,0" Cursor="Hand"
                HorizontalAlignment="Stretch"/>
    </Grid>

    <Window.Resources>
        <DataTemplate x:Key="DeviceItemTemplate">
            <Grid Margin="8,6" Cursor="Hand"
                  MouseLeftButtonDown="OnDeviceClicked">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Path Grid.Column="0" Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4Z"
                      Fill="#6366F1" Width="20" Height="20" Margin="0,0,12,0"
                      VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding DeviceName}" FontSize="14" Foreground="White"/>
                    <TextBlock Text="{Binding DeviceId}" FontSize="10" Foreground="#66FFFFFF"/>
                </StackPanel>

                <TextBlock Grid.Column="2"
                           FontSize="11" Foreground="#99FFFFFF" VerticalAlignment="Center">
                    <TextBlock.Text>
                        <Binding Path="SignalStrength" StringFormat="{}{0} dBm"/>
                    </TextBlock.Text>
                </TextBlock>
            </Grid>
        </DataTemplate>
    </Window.Resources>
</Window>
