<Window x:Class="HeartRateMonitor.App.Views.DevicePickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:HeartRateMonitor.App.Converters"
        mc:Ignorable="d"
        Title="选择设备" Width="360" Height="440"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <DataTemplate x:Key="DeviceItemTemplate">
            <Border Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,0,0,4"
                    Cursor="Hand" MouseLeftButtonDown="OnDeviceClicked">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Opacity1ABrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource PrimaryOpacityBrush}" CornerRadius="20" Width="36" Height="36"
                            Margin="0,0,12,0" VerticalAlignment="Center">
                        <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4Z"
                              Fill="{StaticResource PrimaryBrush}" Width="18" Height="18"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DeviceName}" FontSize="13" Foreground="White" FontWeight="Medium"/>
                        <TextBlock Text="{Binding DeviceId, StringFormat='ID: {0}'}"
                                   FontSize="10" Foreground="{StaticResource Opacity4DBrush}" Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <TextBlock FontSize="11" Foreground="{StaticResource Opacity99Brush}" HorizontalAlignment="Center">
                            <TextBlock.Text>
                                <Binding Path="SignalStrength" StringFormat="{}{0} dBm"/>
                            </TextBlock.Text>
                        </TextBlock>
                        <Path Data="M2,22L12,2L22,22H2Z" Fill="{StaticResource PrimaryBrush}" Width="12" Height="8"
                              HorizontalAlignment="Center" Margin="0,4,0,0"
                              Opacity="{Binding SignalStrength, Converter={x:Static converters:SignalStrengthToOpacityConverter.Instance}}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border Background="{StaticResource BackgroundBrush}"
            CornerRadius="16"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Margin="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Grid Grid.Row="0" Margin="14,0,6,0" MouseLeftButtonDown="OnTitleBarMouseDown" Background="Transparent">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="M17.71,7.71L12,2H11V9.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L11,14.41V22H12L17.71,16.29L13.41,12L17.71,7.71M13,5.83L15.88,8.71L13,11.58V5.83M15.13,14.41L17.71,17.29L15.13,20.17V14.41Z"
                          Fill="{StaticResource PrimaryBrush}" Width="14" Height="14" Margin="0,0,8,0"
                          VerticalAlignment="Center"/>
                    <TextBlock Text="选择心率设备" FontSize="14" FontWeight="SemiBold" Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Button Style="{StaticResource TitleBarButton}" Click="OnCloseClick"
                        ToolTip="关闭" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                          Fill="{StaticResource DangerBrush}" Width="12" Height="12"/>
                </Button>
            </Grid>

            <!-- 状态提示 -->
            <Border Grid.Row="1" Style="{StaticResource SectionCard}" Margin="12,4,12,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="{StaticResource PrimaryBrush}" Margin="0,0,8,0"
                             VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ScanButtonText, StringFormat='{}● {0}'}"
                               Foreground="{StaticResource Opacity99Brush}" FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- 设备列表 -->
            <Border Grid.Row="2" Style="{StaticResource SectionCard}" Margin="12,8,12,0">
                <ListBox ItemsSource="{Binding Devices}"
                         Background="Transparent" Foreground="{StaticResource E0E0E0Brush}"
                         BorderThickness="0"
                         ItemTemplate="{StaticResource DeviceItemTemplate}"
                         SelectedItem="{Binding SelectedDevice}"/>
            </Border>

            <!-- 底部按钮 -->
            <Grid Grid.Row="3" Margin="12,8,12,12">
                <Button Content="{Binding ScanButtonText}"
                        Command="{Binding ToggleScanCommand}"
                        Style="{StaticResource FooterButton}"
                        Background="{StaticResource PrimaryBrush}" Foreground="White" BorderThickness="0"
                        HorizontalAlignment="Left"/>
                <Button Content="关闭"
                        Click="OnCloseClick"
                        Style="{StaticResource FooterButton}"
                        Background="Transparent" Foreground="{StaticResource Opacity99Brush}" BorderBrush="{StaticResource BorderBrush}"
                        HorizontalAlignment="Right"/>
            </Grid>
        </Grid>
    </Border>
</Window>
