<Window x:Class="HeartRateMonitor.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="设置" Width="380" Height="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Border Background="{StaticResource BackgroundBrush}"
            CornerRadius="16"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Margin="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Grid Grid.Row="0" Margin="14,0,6,0" MouseLeftButtonDown="OnTitleBarMouseDown" Background="Transparent">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="M12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8M12,10A2,2 0 0,0 10,12A2,2 0 0,0 12,14A2,2 0 0,0 14,12A2,2 0 0,0 12,10M20.5,18.5L15,13L15,16A1,1 0 0,1 14,17H10A1,1 0 0,1 9,16V13L3.5,18.5L5,20L10,15V17H14V15L19,20L20.5,18.5Z"
                          Fill="{StaticResource Opacity99Brush}" Width="14" Height="14" Margin="0,0,8,0"
                          VerticalAlignment="Center"/>
                    <TextBlock Text="设置" FontSize="14" FontWeight="SemiBold" Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Button Style="{StaticResource TitleBarButton}" Click="OnCloseClick"
                        ToolTip="关闭" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                          Fill="{StaticResource DangerBrush}" Width="12" Height="12"/>
                </Button>
            </Grid>

            <!-- 内容区 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="12,4,12,0"
                          Style="{StaticResource ThemedScrollViewer}">
                <StackPanel>
                    <!-- 连接 -->
                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitle}" Text="连接"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource SettingLabel}" Text="自动连接上次设备"/>
                                    <TextBlock Style="{StaticResource SettingDescription}" Text="启动时自动重连上次使用的蓝牙设备"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding AutoConnect}" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 心率警报 -->
                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitle}" Text="心率警报"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource SettingLabel}" Text="通知提醒"/>
                                    <TextBlock Style="{StaticResource SettingDescription}" Text="心率超出阈值时弹出系统通知"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding EnableNotifications}" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource SettingLabel}" Text="声音警报"/>
                                    <TextBlock Style="{StaticResource SettingDescription}" Text="心率超出阈值时播放提示音"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding EnableSoundAlert}" VerticalAlignment="Center"/>
                            </Grid>
                            <Border Style="{StaticResource SectionSeparator}"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource SettingLabel}" Text="心率上限阈值"/>
                                <TextBox Grid.Column="1" Style="{StaticResource InputTextBox}"
                                         Text="{Binding HighHeartRateThreshold, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource SettingLabel}" Text="心率下限阈值"/>
                                <TextBox Grid.Column="1" Style="{StaticResource InputTextBox}"
                                         Text="{Binding LowHeartRateThreshold, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 外观 -->
                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitle}" Text="外观"/>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource SettingLabel}" Text="窗口不透明度"/>
                                <TextBlock Grid.Column="1" Text="{Binding OverlayOpacity, StringFormat={}{0:P0}}"
                                           Foreground="{StaticResource Opacity99Brush}" FontSize="12" VerticalAlignment="Center"/>
                            </Grid>
                            <Slider Style="{StaticResource SliderStyle}"
                                    Minimum="0.3" Maximum="1.0" Value="{Binding OverlayOpacity, UpdateSourceTrigger=PropertyChanged}"
                                    TickFrequency="0.05" IsSnapToTickEnabled="True" Margin="0,0,0,12"/>
                            <Border Style="{StaticResource SectionSeparator}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource SettingLabel}" Text="极简模式"/>
                                    <TextBlock Style="{StaticResource SettingDescription}" Text="仅显示心跳状态和速度数据"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding MinimalMode}" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 系统 -->
                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitle}" Text="系统"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource SettingLabel}" Text="开机自动启动"/>
                                    <TextBlock Style="{StaticResource SettingDescription}" Text="Windows启动时自动运行应用"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding StartWithWindows}" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource SettingLabel}" Text="最小化到系统托盘"/>
                                    <TextBlock Style="{StaticResource SettingDescription}" Text="关闭窗口时最小化到通知区域"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding MinimizeToTray}" VerticalAlignment="Center"/>
                            </Grid>
                            <Border Style="{StaticResource SectionSeparator}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource SettingLabel}" Text="数据保留天数"/>
                                    <TextBlock Style="{StaticResource SettingDescription}" Text="超出天数的历史数据将自动清理"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Style="{StaticResource InputTextBox}"
                                         Text="{Binding DataRetentionDays, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- 底部按钮 -->
            <Grid Grid.Row="2" Margin="12,8,12,12">
                <Button Content="恢复默认" Command="{Binding ResetDefaultsCommand}"
                        Style="{StaticResource FooterButton}"
                        Background="Transparent" Foreground="{StaticResource Opacity99Brush}" BorderBrush="{StaticResource BorderBrush}"
                        HorizontalAlignment="Left"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消" Click="OnCancelClick"
                            Style="{StaticResource FooterButton}"
                            Background="Transparent" Foreground="{StaticResource Opacity99Brush}" BorderBrush="{StaticResource BorderBrush}"
                            Margin="0,0,8,0"/>
                    <Button Content="保存" Command="{Binding SaveCommand}"
                            Style="{StaticResource FooterButton}"
                            Background="{StaticResource PrimaryBrush}" Foreground="White" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
