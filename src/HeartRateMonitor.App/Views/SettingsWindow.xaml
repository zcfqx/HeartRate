<Window x:Class="HeartRateMonitor.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="设置" Width="420" Height="560"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A2E"
        Foreground="#E0E0E0"
        ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="设置"
                   FontSize="24" FontWeight="SemiBold" Foreground="White"
                   Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="连接" Foreground="#4DFFFFFF" FontSize="11" Margin="0,0,0,8"/>
                <CheckBox Content="自动连接上次设备"
                          IsChecked="{Binding AutoConnect}"
                          Foreground="#B3FFFFFF" Margin="0,0,0,8"/>

                <Border Height="1" Background="#1AFFFFFF" Margin="0,12,0,12"/>

                <TextBlock Text="警报" Foreground="#4DFFFFFF" FontSize="11" Margin="0,0,0,8"/>
                <CheckBox Content="启用通知提醒"
                          IsChecked="{Binding EnableNotifications}"
                          Foreground="#B3FFFFFF" Margin="0,0,0,8"/>
                <CheckBox Content="启用声音警报"
                          IsChecked="{Binding EnableSoundAlert}"
                          Foreground="#B3FFFFFF" Margin="0,0,0,8"/>

                <Grid Margin="0,8,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="心率上限阈值" Foreground="#B3FFFFFF" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding HighHeartRateThreshold}"
                             Background="#0DFFFFFF" Foreground="White" BorderBrush="#33FFFFFF"
                             Padding="4" HorizontalContentAlignment="Center"/>
                </Grid>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="心率下限阈值" Foreground="#B3FFFFFF" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding LowHeartRateThreshold}"
                             Background="#0DFFFFFF" Foreground="White" BorderBrush="#33FFFFFF"
                             Padding="4" HorizontalContentAlignment="Center"/>
                </Grid>

                <Border Height="1" Background="#1AFFFFFF" Margin="0,12,0,12"/>

                <TextBlock Text="外观" Foreground="#4DFFFFFF" FontSize="11" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="主题" Foreground="#B3FFFFFF" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" SelectedItem="{Binding Theme}"
                              Background="#0DFFFFFF" Foreground="White" BorderBrush="#33FFFFFF">
                        <ComboBoxItem Content="深色" IsSelected="True"/>
                        <ComboBoxItem Content="浅色"/>
                    </ComboBox>
                </Grid>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="窗口不透明度" Foreground="#B3FFFFFF" VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" Minimum="0.3" Maximum="1.0"
                            Value="{Binding OverlayOpacity}" TickFrequency="0.1"
                            IsSnapToTickEnabled="True"/>
                </Grid>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="界面语言" Foreground="#B3FFFFFF" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" SelectedItem="{Binding Language}"
                              Background="#0DFFFFFF" Foreground="White" BorderBrush="#33FFFFFF">
                        <ComboBoxItem Content="简体中文" IsSelected="True"/>
                        <ComboBoxItem Content="English"/>
                    </ComboBox>
                </Grid>

                <Border Height="1" Background="#1AFFFFFF" Margin="0,12,0,12"/>

                <TextBlock Text="系统" Foreground="#4DFFFFFF" FontSize="11" Margin="0,0,0,8"/>
                <CheckBox Content="开机自动启动"
                          IsChecked="{Binding StartWithWindows}"
                          Foreground="#B3FFFFFF" Margin="0,0,0,8"/>
                <CheckBox Content="最小化到系统托盘"
                          IsChecked="{Binding MinimizeToTray}"
                          Foreground="#B3FFFFFF" Margin="0,0,0,8"/>

                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="数据保留天数" Foreground="#B3FFFFFF" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding DataRetentionDays}"
                             Background="#0DFFFFFF" Foreground="White" BorderBrush="#33FFFFFF"
                             Padding="4" HorizontalContentAlignment="Center"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="恢复默认" Command="{Binding ResetDefaultsCommand}"
                    Background="Transparent" Foreground="#99FFFFFF" BorderBrush="#33FFFFFF"
                    Padding="12,6" Margin="0,0,8,0" Cursor="Hand"/>
            <Button Content="保存" Command="{Binding SaveCommand}"
                    Background="#6366F1" Foreground="White" BorderThickness="0"
                    Padding="16,6" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
